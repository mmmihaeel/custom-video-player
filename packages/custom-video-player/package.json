{
  "name": "@mmmihaeel/custom-video-player",
  "version": "0.1.0",
  "description": "Reusable React video player package with HLS playback, chapter-aware timeline, and custom controls.",
  "author": "mmmihaeel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmmihaeel/custom-video-player.git",
    "directory": "packages/custom-video-player"
  },
  "bugs": {
    "url": "https://github.com/mmmihaeel/custom-video-player/issues"
  },
  "homepage": "https://mmmihaeel.github.io/custom-video-player/",
  "type": "module",
  "keywords": [
    "react",
    "video-player",
    "hls",
    "chapters",
    "custom-player"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/custom-video-player.css"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\" \"vite.config.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "hls.js": "^1.5.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.30",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.23.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "vite": "^6.2.2",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.0.9"
  }
}
